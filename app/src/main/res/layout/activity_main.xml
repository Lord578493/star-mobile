<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/card">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="✈  TG Bypass"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle"
            android:backgroundTint="@color/gray"/>
    </LinearLayout>

    <!-- Статус -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card"
        android:padding="16dp"
        android:layout_marginTop="1dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Не активен"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStatusSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нажмите ЗАПУСТИТЬ"
            android:textColor="@color/subtext"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Кнопка -->
    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="ЗАПУСТИТЬ"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/accent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"/>

    <!-- Режимы -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="РЕЖИМ ОБХОДА"
        android:textColor="@color/subtext"
        android:textSize="11sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="4dp"/>

    <RadioGroup
        android:id="@+id/radioGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <RadioButton
            android:id="@+id/radioBasic"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Базовый"
            android:tag="BASIC"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:buttonTint="@color/accent"/>

        <RadioButton
            android:id="@+id/radioEnhanced"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="⭐ Усиленный (рекомендуется)"
            android:tag="ENHANCED"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:buttonTint="@color/accent"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radioMax"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Максимальный"
            android:tag="MAXIMUM"
            android:textColor="@color/text"
            android:textSize="15sp"
            android:buttonTint="@color/accent"/>
    </RadioGroup>

    <!-- Автозапуск -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Автозапуск при загрузке"
            android:textColor="@color/text"
            android:textSize="14sp"/>

        <Switch
            android:id="@+id/switchAutostart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="@color/accent"
            android:trackTint="@color/divider"/>
    </LinearLayout>

    <!-- Консоль логов -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="КОНСОЛЬ"
        android:textColor="@color/subtext"
        android:textSize="11sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"/>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@color/card"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ожидание запуска...\n"
            android:textColor="#00FF88"
            android:textSize="11sp"
            android:fontFamily="monospace"/>
    </ScrollView>

</LinearLayout>
